# Environment and secrets — NEVER commit (this repo is public)
.env
.env.*
!.env.example
garage/garage.toml
ansible/secrets.yml
ansible/secrets.*.yml
ansible/**/vault.yml
ansible/**/*.vault

# Credentials / private keys / certs
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519
.pgpass
*.retry
vault-password*
.vault_pass*

# Supervisor / planning docs — local guidance, kept out of the repo
CLAUDE.md
APPLICATION_STATE.md
DEVOPS.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
*.whl

# Node
node_modules/
frontend/dist/

# Vagrant — local VM state, INCLUDING a generated private SSH key. Never commit.
.vagrant/
*.box

# Terraform — defense-in-depth (see also terraform/.gitignore). State can hold secrets.
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.coverage
htmlcov/
.pytest_cache/
