# Rendered on the VM by deploy-app.yml. NOT committed (matches .env gitignore rule).
APP_ENV=production

# Compose project name isolates this stack (containers/networks/volumes) from any
# other stack on the same VM (e.g. prod=qr-generator, staging=qr-staging).
COMPOSE_PROJECT_NAME={{ compose_project }}

# Host-published Garage ports (differ per stack so prod and staging don't collide).
GARAGE_S3_PORT={{ garage_s3_port }}
GARAGE_ADMIN_PORT={{ garage_admin_port }}

POSTGRES_PASSWORD={{ postgres_password }}

S3_PUBLIC_URL={{ s3_public_url }}
S3_ACCESS_KEY={{ s3_access_key }}
S3_SECRET_KEY={{ s3_secret_key }}

CORS_ORIGINS={{ cors_origins }}

BACKEND_IMAGE={{ image_namespace }}/backend:{{ image_tag }}
FRONTEND_IMAGE={{ image_namespace }}/frontend:{{ image_tag }}
FRONTEND_PORT={{ frontend_port }}
