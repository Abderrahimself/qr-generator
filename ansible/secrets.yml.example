# Copy to ansible/secrets.yml (git-ignored) and fill in — or encrypt with ansible-vault.
# Pass to the deploy: cd ansible && ansible-playbook -i inventory/local.yml playbooks/deploy-app.yml -e @secrets.yml
#
# Generate strong values:
#   garage_rpc_secret / s3_secret_key : openssl rand -hex 32
#   postgres_password                 : openssl rand -base64 24

# App image location on GHCR — ghcr.io/<owner>/<repo>
image_namespace: "ghcr.io/OWNER/REPO"
image_tag: "latest"

# GHCR pull credentials (a PAT with read:packages, or the Actions GITHUB_TOKEN)
ghcr_username: "OWNER"
ghcr_token: "REPLACE_WITH_TOKEN"

# Secrets (imported into Garage so the app's S3 creds match)
postgres_password: "REPLACE_ME"
garage_rpc_secret: "REPLACE_ME_openssl_rand_hex_32"
s3_access_key: "GKREPLACEME"
s3_secret_key: "REPLACE_ME_openssl_rand_hex_32"

# Public-facing config (browser-reachable Garage endpoint + app origin)
s3_public_url: "http://192.168.60.2:3900"
cors_origins: "http://192.168.60.2"
frontend_port: 80
