# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# PostgreSQL (runs in Podman via compose.dev.yml)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qr_generator

# Valkey (runs in Podman via compose.dev.yml — NOT Redis)
VALKEY_HOST=localhost
VALKEY_PORT=6379
CACHE_TTL_SECONDS=86400

# Garage (runs in Podman via compose.dev.yml — NOT MinIO)
S3_ENDPOINT_URL=http://localhost:3900
S3_ACCESS_KEY=your-garage-access-key
S3_SECRET_KEY=your-garage-secret-key
S3_BUCKET_NAME=qr-codes
S3_REGION=garage

# QR defaults
QR_DEFAULT_FORMAT=png
QR_DEFAULT_SIZE=10
QR_DEFAULT_BORDER=4
